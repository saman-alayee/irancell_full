PORT=3001
MONGODB_URI=mongodb://localhost:27017/irancell_shop
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ZarinPal
ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_URL=http://localhost:3001/api/payment/verify

# Frontend URL (for CORS & redirects)
FRONTEND_URL=http://localhost:3000

# Admin seed (optional)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456

# User registration requires: firstName, lastName, fatherName, nationalId (10 digits), mobile, secondMobile

# SMS.ir — OTP verification (template: قالب ارسال سریع 2 — #VERIFICATIONCODE#)
SMS_IR_API_KEY=your-sms-ir-api-key
SMS_IR_TEMPLATE_ID=553188
SMS_IR_CODE_PARAM=VERIFICATIONCODE
SMS_IR_DEV_MODE=false
