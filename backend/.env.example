PORT=3001
MONGODB_URI=mongodb://localhost:27017/irancell_shop
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ZarinPal
ZARINPAL_MERCHANT_ID=4d025349-150c-4fca-81ad-6fe936e107e9
ZARINPAL_SANDBOX=false
ZARINPAL_CALLBACK_URL=https://irancell-31038.ir/api/payment/verify

# Zibal
ZIBAL_MERCHANT_ID=
ZIBAL_CALLBACK_URL=https://irancell-31038.ir/api/payment/verify/zibal

# Frontend URL (for CORS & redirects)
FRONTEND_URL=http://localhost:3000

# Admin seed (optional)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456

# User registration requires: firstName, lastName, fatherName, nationalId, address, mobile, secondMobile

# SMS.ir — OTP (#VERIFICATIONCODE#) + payment success (#ORDER_NUMBER#)
SMS_IR_API_KEY=your-sms-ir-api-key
SMS_IR_TEMPLATE_ID=553188
SMS_IR_CODE_PARAM=VERIFICATIONCODE
SMS_IR_PAYMENT_TEMPLATE_ID=352975
SMS_IR_PAYMENT_ORDER_PARAM=ORDER_NUMBER
SMS_IR_DEV_MODE=false

# Irancell shop — price & availability lookup (apishop.irancell.ir)
IRANCELL_SHOP_API_BASE=https://apishop.irancell.ir
IRANCELL_SHOP_CHANNEL=eShop
# true = mock data for local dev without Iran network; false = live API
IRANCELL_SHOP_DEV_MODE=false
IRANCELL_SHOP_TIMEOUT_MS=12000
IRANCELL_LOOKUP_DELAY_MS=250
IRANCELL_LOOKUP_CONCURRENCY=4
